# =============================================================================
# Configuration d'environnement - BookYourCoach
# =============================================================================

# Application Laravel
APP_NAME=BookYourCoach
APP_ENV=production
APP_KEY=base64:YOUR_APP_KEY_HERE
APP_DEBUG=false
APP_URL=https://activibe.be
FRONTEND_URL=https://activibe.be

# Base de données
DB_CONNECTION=mysql
DB_HOST=your-db-host
DB_PORT=3306
DB_DATABASE=book_your_coach
DB_USERNAME=your-db-username
DB_PASSWORD=your-db-password

# Cache, sessions, queues — prod : VM partagée (infra/shared-redis/, ~6-8 €/mois e2-micro)
CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

# Redis local Docker : REDIS_HOST=redis, REDIS_DB=0, REDIS_CACHE_DB=1
# Redis VM partagée GCP (infra/shared-redis/) : DB 3 sessions/queues, DB 4 cache
# Secret Manager : bookyourcoach-redis-url, bookyourcoach-redis-cache-url
# Host : premedica-redis-host
REDIS_CLIENT=phpredis
REDIS_HOST=IP_INTERNE
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=3
REDIS_CACHE_DB=4

# Mail
MAIL_MAILER=smtp
# Pour développement local avec MailHog (docker-compose.local.yml)
# MAIL_HOST=mailhog
# MAIL_PORT=1025
# MAIL_USERNAME=null
# MAIL_PASSWORD=null
# MAIL_ENCRYPTION=null
# Pour production
MAIL_HOST=your-smtp-host
MAIL_PORT=587
MAIL_USERNAME=your-email@domain.com
MAIL_PASSWORD=your-email-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@activibe.be
MAIL_FROM_NAME="BookYourCoach"

# Google Gemini AI Configuration
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
GEMINI_MODEL=gemini-2.5-flash

# Neo4j
NEO4J_PASSWORD=your-neo4j-password

# Images Docker
BACKEND_IMAGE=olegrand1976/activibe-app
FRONTEND_IMAGE=olegrand1976/activibe-frontend

# Frontend
FRONTEND_API_BASE=https://activibe.be/api
FRONTEND_URL=https://activibe.be

# Sécurité
SANCTUM_STATEFUL_DOMAINS=activibe.be,localhost:3000
SESSION_DOMAIN=.activibe.be
